{
  "name": "@vanduo-oss/vd3",
  "version": "0.1.0",
  "description": "Vanduo UI for Vue 3 — design system and component library (the vd3 line)",
  "type": "module",
  "homepage": "https://github.com/vanduo-oss/vd3#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vanduo-oss/vd3.git"
  },
  "bugs": {
    "url": "https://github.com/vanduo-oss/vd3/issues"
  },
  "license": "MIT",
  "author": "vanduo-oss",
  "keywords": [
    "vue",
    "vue3",
    "components",
    "composables",
    "design-system",
    "design-tokens",
    "ui",
    "css",
    "vanduo"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "SKILL.md",
    "CHANGELOG.md",
    "LICENSE",
    "THIRD-PARTY-LICENSES"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css": "./dist/vd3.min.css",
    "./css/core": "./dist/vd3-core.min.css",
    "./tokens.json": "./dist/tokens.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && node scripts/build-tokens.mjs && node scripts/build-css.mjs && vite build && vue-tsc -p tsconfig.build.json",
    "build:tokens": "node scripts/build-tokens.mjs",
    "build:css": "node scripts/build-css.mjs",
    "gen:fib": "node scripts/generate-fib-palette.mjs",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,vue}\" \"tests/**/*.ts\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue}\" \"tests/**/*.ts\" \"scripts/**/*.mjs\"",
    "stylelint": "stylelint \"css/**/*.css\"",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.0",
    "@typescript-eslint/parser": "8.62.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "prettier": "^3.9.1",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue": "^3.5.38",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.28.2"
}
